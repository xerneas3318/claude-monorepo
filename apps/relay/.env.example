# Copy to .env on the server (gitignored). The systemd unit reads from
# /etc/claudeplanner-relay/.env in the example below.

# Anthropic API key (sk-ant-...)
ANTHROPIC_API_KEY=

# Model override; default = claude-opus-4-7
ANTHROPIC_MODEL=claude-opus-4-7

# Firebase project id (must match the iOS app)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to the Firebase service account JSON (same one the sync daemon uses).
# Generate one at: Firebase Console -> Project Settings -> Service accounts.
GOOGLE_APPLICATION_CREDENTIALS=/etc/claudeplanner-relay/service-account.json

# Listen address. Bind to localhost and put Caddy/nginx in front for TLS.
HOST=127.0.0.1
PORT=8787

# Optional: restrict to specific Firebase UIDs (comma-separated). If empty,
# any signed-in user from your project can hit the relay. For a single-user
# app, pin to your UID here for an extra belt-and-suspenders check.
ALLOWED_UIDS=
